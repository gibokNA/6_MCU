# /etc/nginx/sites-available/kurento

# 1. 업스트림(백엔드) 정의
# Node.js가 실행 중인 로컬 포트 지정
upstream mcu_backend {
    server 127.0.0.1:3000;
}

server {
    # 일단 80포트(HTTP)로 받음 -> 나중에 Certbot이 443(HTTPS) 설정을 자동으로 추가해줌
    listen 80;
    server_name mcu.nagibok-live-streaming.in;

    # [로그 설정] 문제 생기면 여기를 봐야 함
    access_log /var/log/nginx/kurento_access.log;
    error_log /var/log/nginx/kurento_error.log;

    # [핵심] 리버스 프록시 설정
    location / {
        proxy_pass http://mcu_backend; # 요청을 Node.js로 전달

        # [헤더 전달] 실제 사용자의 IP를 Node.js에게 알려줌
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Host $http_host;
        proxy_set_header X-NginX-Proxy true;

        # [WebSocket 지원] Socket.io 연결을 위한 필수 설정! (이거 없으면 접속 안 됨)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        
        # 타임아웃 설정 (긴 회의 연결 유지)
        proxy_read_timeout 86400;
    }
}